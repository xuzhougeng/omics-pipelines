import pandas as pd

configfile: "config.yaml"

# --- Load sample metadata ---
samples_df = pd.read_csv("samples.tsv", sep="\t", comment="#")
SAMPLES = samples_df.set_index("sample", drop=False)

# --- IP vs input ---
# A sample is an IP if it names a `control` (its matched input). Input/control
# rows leave `control` empty. Peak calling and IP/input ratio tracks only run
# for IP samples; everything upstream (QC -> filtered BAM -> coverage) runs for
# every sample, inputs included.
def _has_control(v):
    return pd.notna(v) and str(v).strip() != ""

IP_SAMPLES = [s for s in SAMPLES.index if _has_control(SAMPLES.loc[s, "control"])]

def control_of(sample):
    return str(SAMPLES.loc[sample, "control"]).strip()

def control_bam(wc):
    c = control_of(wc.sample)
    return f"results/04-bam-postprecessing/{c}/{c}.filtered.bam"

def control_bai(wc):
    return control_bam(wc) + ".bai"

# --- Reference config ---
REF = config["ref"]
NUCLEAR_CHROMS = ",".join(config["filter_bam"]["nuclear_chroms"])
MAPQ_THRESHOLD = config["filter_bam"]["mapq_threshold"]

# External reference files (ancient = not generated by this pipeline)
BOWTIE2_IDX = ancient(REF["bowtie2_index"] + ".1.bt2")
GTF = ancient(REF["gtf"])

rule all:
    input:
        # raw-read FastQC (sentinel) + fastp report + clean-read FastQC
        expand("results/01-fastp-qc/{sample}/.raw_fastqc.done", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/{sample}_fastp.html", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/clean_fastqc/{sample}_1_fastqc.html", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/clean_fastqc/{sample}_2_fastqc.html", sample=SAMPLES.index),
        # alignment
        expand("results/02-read-alignment/{sample}/{sample}.bam", sample=SAMPLES.index),
        # mark duplicates
        expand("results/03-mark-duplication/{sample}/{sample}.bam", sample=SAMPLES.index),
        # filtered BAMs (every sample, inputs included)
        expand("results/04-bam-postprecessing/{sample}/{sample}.filtered.bam.bai", sample=SAMPLES.index),
        # per-sample coverage bigwig
        expand("results/05-deeptools-bigwig/{sample}/{sample}.filtered.bw", sample=SAMPLES.index),
        # IP-vs-input log2 ratio bigwig (IP samples only)
        expand("results/06-deeptools-bigwig-compare/{sample}/{sample}.log2ratio.bw", sample=IP_SAMPLES),
        # MACS3 peaks (IP samples only, called against their input)
        expand("results/07-peak_calling/{sample}/{sample}_peaks.narrowPeak", sample=IP_SAMPLES),
        # consensus peaks
        "results/09-peak-quant/consensus_peaks.bed",
        # featureCounts
        "results/09-peak-quant/featurecounts/counts.tsv",
        # ChIPseeker annotation
        "results/09-peak-quant/peaks_annotated.tsv",

# ============================================================
# Step 1: FastQC on raw reads
# ============================================================
rule fastqc_raw:
    input:
        r1=lambda wc: SAMPLES.loc[wc.sample, "r1"],
        r2=lambda wc: SAMPLES.loc[wc.sample, "r2"],
    output:
        done=temp("results/01-fastp-qc/{sample}/.raw_fastqc.done"),
    log:
        "logs/01-fastp-qc/{sample}_fastqc_raw.log",
    params:
        threads=config["fastqc"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample}/raw_fastqc && "
        "pixi run -e default fastqc -o results/01-fastp-qc/{wildcards.sample}/raw_fastqc "
        "-t {params.threads} {input.r1} {input.r2} "
        "> {log} 2>&1 && "
        "touch {output.done}"

# ============================================================
# Step 2: fastp adapter trimming
# ============================================================
rule fastp:
    input:
        r1=lambda wc: SAMPLES.loc[wc.sample, "r1"],
        r2=lambda wc: SAMPLES.loc[wc.sample, "r2"],
    output:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
        html="results/01-fastp-qc/{sample}/{sample}_fastp.html",
        json="results/01-fastp-qc/{sample}/{sample}_fastp.json",
    log:
        "logs/01-fastp-qc/{sample}_fastp.log",
    params:
        length_required=config["fastp"]["length_required"],
        qual_phred=config["fastp"]["qualified_quality_phred"],
        unqual_limit=config["fastp"]["unqualified_percent_limit"],
        n_base=config["fastp"]["n_base_limit"],
        threads=config["fastp"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample} && "
        "pixi run -e default fastp "
        "-i {input.r1} -I {input.r2} "
        "-o {output.r1} -O {output.r2} "
        "-h {output.html} -j {output.json} "
        "--thread {params.threads} "
        "--detect_adapter_for_pe "
        "--length_required {params.length_required} "
        "--qualified_quality_phred {params.qual_phred} "
        "--unqualified_percent_limit {params.unqual_limit} "
        "--n_base_limit {params.n_base} "
        "> {log} 2>&1"

# ============================================================
# Step 3: FastQC on clean reads
# ============================================================
rule fastqc_clean:
    input:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
    output:
        r1_html="results/01-fastp-qc/{sample}/clean_fastqc/{sample}_1_fastqc.html",
        r2_html="results/01-fastp-qc/{sample}/clean_fastqc/{sample}_2_fastqc.html",
    log:
        "logs/01-fastp-qc/{sample}_fastqc_clean.log",
    params:
        threads=config["fastqc"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample}/clean_fastqc && "
        "pixi run -e default fastqc -o results/01-fastp-qc/{wildcards.sample}/clean_fastqc "
        "-t {params.threads} {input.r1} {input.r2} "
        "> {log} 2>&1"

# ============================================================
# Step 4: bowtie2 alignment + samtools sort
# ============================================================
rule bowtie2_align:
    input:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
        idx=BOWTIE2_IDX,
    output:
        bam="results/02-read-alignment/{sample}/{sample}.bam",
    log:
        "logs/02-read-alignment/{sample}.log",
    params:
        idx_prefix=REF["bowtie2_index"],
        preset=config["bowtie2"]["preset"],
        max_fragment=config["bowtie2"]["max_fragment_length"],
        bowtie2_threads=config["bowtie2"]["threads"],
        sort_threads=config["samtools_sort"]["threads"],
    shell:
        "mkdir -p results/02-read-alignment/{wildcards.sample} && "
        "pixi run -e default bowtie2 "
        "-x {params.idx_prefix} "
        "-1 {input.r1} -2 {input.r2} "
        "--threads {params.bowtie2_threads} "
        "{params.preset} "
        "-X {params.max_fragment} "
        "2> {log} | "
        "pixi run -e deeptools samtools sort -@ {params.sort_threads} -o {output.bam} - "

# ============================================================
# Step 5: sambamba mark duplicates
# ============================================================
rule sambamba_markdup:
    input:
        bam="results/02-read-alignment/{sample}/{sample}.bam",
    output:
        bam="results/03-mark-duplication/{sample}/{sample}.bam",
    log:
        "logs/03-mark-duplication/{sample}.log",
    params:
        threads=config["sambamba"]["threads"],
        overflow=config["sambamba"]["overflow_list_size"],
        hash_size=config["sambamba"]["hash_table_size"],
    shell:
        "mkdir -p results/03-mark-duplication/{wildcards.sample} "
        "results/03-mark-duplication/{wildcards.sample}/tmp && "
        "pixi run -e default sambamba markdup "
        "-t {params.threads} "
        "--tmpdir results/03-mark-duplication/{wildcards.sample}/tmp "
        "--overflow-list-size {params.overflow} "
        "--hash-table-size {params.hash_size} "
        "{input.bam} {output.bam} "
        "> {log} 2>&1"

# ============================================================
# Step 6: Filter BAM (dedup, nuclear chroms, MAPQ, proper pairs)
# No Tn5 shift — that is ATAC-specific.
# ============================================================
rule filter_bam:
    input:
        bam="results/03-mark-duplication/{sample}/{sample}.bam",
    output:
        filtered="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam",
        filtered_bai="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam.bai",
    log:
        "logs/04-bam-postprecessing/{sample}.log",
    params:
        chroms=NUCLEAR_CHROMS,
        mapq=MAPQ_THRESHOLD,
    shell:
        "mkdir -p results/04-bam-postprecessing/{wildcards.sample} && "
        "pixi run -e default python scripts/snakemake_filter_bam.py "
        "{input.bam} {output.filtered} "
        "{params.chroms} {params.mapq} "
        "> {log} 2>&1"

# ============================================================
# Step 7: Per-sample coverage bigwig
# ============================================================
rule bigwig:
    input:
        bam="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam",
        bai="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam.bai",
    output:
        bw="results/05-deeptools-bigwig/{sample}/{sample}.filtered.bw",
    log:
        "logs/05-deeptools-bigwig/{sample}.log",
    params:
        bin_size=config["bigwig"]["bin_size"],
        normalize=config["bigwig"]["normalize_using"],
    shell:
        "mkdir -p results/05-deeptools-bigwig/{wildcards.sample} && "
        "pixi run -e deeptools bamCoverage "
        "-b {input.bam} "
        "-o {output.bw} "
        "--binSize {params.bin_size} "
        "--normalizeUsing {params.normalize} "
        "--extendReads "
        "--numberOfProcessors 4 "
        "> {log} 2>&1"

# ============================================================
# Step 8: IP-vs-input log2 ratio bigwig (IP samples only)
# ============================================================
rule bigwig_compare:
    input:
        ip="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam",
        ip_bai="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam.bai",
        control=control_bam,
        control_bai=control_bai,
    output:
        bw="results/06-deeptools-bigwig-compare/{sample}/{sample}.log2ratio.bw",
    log:
        "logs/06-deeptools-bigwig-compare/{sample}.log",
    params:
        bin_size=config["bigwig_compare"]["bin_size"],
        operation=config["bigwig_compare"]["operation"],
    shell:
        "mkdir -p results/06-deeptools-bigwig-compare/{wildcards.sample} && "
        "pixi run -e deeptools bamCompare "
        "-b1 {input.ip} -b2 {input.control} "
        "-o {output.bw} "
        "--binSize {params.bin_size} "
        "--operation {params.operation} "
        "--extendReads "
        "--numberOfProcessors 4 "
        "> {log} 2>&1"

# ============================================================
# Step 9: MACS3 peak calling against input control (IP samples only)
# ============================================================
rule macs3_callpeak:
    input:
        ip="results/04-bam-postprecessing/{sample}/{sample}.filtered.bam",
        control=control_bam,
    output:
        narrowPeak="results/07-peak_calling/{sample}/{sample}_peaks.narrowPeak",
    log:
        "logs/07-peak_calling/{sample}.log",
    params:
        genome=REF["macs_genome"],
        format=config["macs3"]["format"],
        qvalue=config["macs3"]["qvalue"],
        keep_dup=config["macs3"]["keep_dup"],
    shell:
        "mkdir -p results/07-peak_calling/{wildcards.sample} && "
        "pixi run -e macs3 macs3 callpeak "
        "-t {input.ip} "
        "-c {input.control} "
        "-f {params.format} "
        "-g {params.genome} "
        "--keep-dup {params.keep_dup} "
        "-q {params.qvalue} "
        "--outdir results/07-peak_calling/{wildcards.sample} "
        "-n {wildcards.sample} "
        "> {log} 2>&1"

# ============================================================
# Step 10: Merge IP narrowPeak files into consensus peaks
# ============================================================
rule merge_peaks:
    input:
        peaks=expand("results/07-peak_calling/{sample}/{sample}_peaks.narrowPeak", sample=IP_SAMPLES),
    output:
        bed="results/09-peak-quant/consensus_peaks.bed",
    log:
        "logs/09-peak-quant/merge_peaks.log",
    shell:
        "mkdir -p results/09-peak-quant && "
        "cat {input.peaks} | "
        "awk -v OFS='\\t' '{{print $1, $2, $3}}' | "
        "sort -k1,1 -k2,2n | "
        "pixi run -e peak-quant bedtools merge -i stdin "
        "> {output.bed} 2> {log}"

# ============================================================
# Step 11: featureCounts quantification (all samples, inputs included)
# ============================================================
rule featurecounts:
    input:
        bed="results/09-peak-quant/consensus_peaks.bed",
        bams=expand("results/04-bam-postprecessing/{sample}/{sample}.filtered.bam", sample=SAMPLES.index),
    output:
        counts="results/09-peak-quant/featurecounts/counts.tsv",
    log:
        "logs/09-peak-quant/featurecounts.log",
    params:
        threads=config["featurecounts"]["threads"],
        min_overlap=config["featurecounts"]["min_overlap"],
    shell:
        "mkdir -p results/09-peak-quant/featurecounts && "
        "awk -v OFS='\\t' 'BEGIN {{print \"GeneID\\tChr\\tStart\\tEnd\\tStrand\"}} "
        "{{print \"peak_\"NR, $1, $2+1, $3, \".\"}}' {input.bed} "
        "> results/09-peak-quant/featurecounts/consensus_peaks.saf && "
        "pixi run -e peak-quant featureCounts "
        "-T {params.threads} -p -B -O "
        "--minOverlap {params.min_overlap} "
        "-F SAF "
        "-a results/09-peak-quant/featurecounts/consensus_peaks.saf "
        "-o {output.counts} "
        "{input.bams} "
        "> {log} 2>&1"

# ============================================================
# Step 12: ChIPseeker peak annotation
# ============================================================
rule chipseeker_annotate:
    input:
        bed="results/09-peak-quant/consensus_peaks.bed",
        gtf=GTF,
    output:
        tsv="results/09-peak-quant/peaks_annotated.tsv",
    log:
        "logs/09-peak-quant/chipseeker_annotate.log",
    params:
        organism=config["chipseeker"]["organism"],
        anno_db=config["chipseeker"]["anno_db"],
        tss_low=config["chipseeker"]["tss_region"][0],
        tss_high=config["chipseeker"]["tss_region"][1],
    shell:
        "pixi run -e chipseeker Rscript scripts/snakemake_chipseeker.R "
        "{input.bed} {input.gtf} {output.tsv} "
        "'{params.organism}' {params.anno_db} {params.tss_low} {params.tss_high} "
        "> {log} 2>&1"
