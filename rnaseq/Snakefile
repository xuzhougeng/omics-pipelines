import pandas as pd

configfile: "config.yaml"

# --- Load sample metadata ---
samples_df = pd.read_csv("samples.tsv", sep="\t", comment="#")
SAMPLES = samples_df.set_index("sample", drop=False)

# --- Differential-expression groups ---
# Groups are ordered by first appearance in samples.tsv. The FIRST group is the
# reference (WT); every other group is contrasted against it:
#   group2 vs group1, group3 vs group1, ...
GROUPS = list(dict.fromkeys(SAMPLES["group"]))
REF_GROUP = GROUPS[0]
CONTRASTS = [f"{g}_vs_{REF_GROUP}" for g in GROUPS[1:]]

# --- Reference config ---
REF = config["ref"]

# External reference files (ancient = not generated by this pipeline).
# The STAR index is expected to be built WITH the GTF baked in (see README),
# so gene counting works without re-inserting annotations at mapping time.
STAR_INDEX = REF["star_index"]
STAR_SAINDEX = ancient(STAR_INDEX + "/SAindex")

rule all:
    input:
        # raw-read FastQC (sentinel) + fastp report + clean-read FastQC
        expand("results/01-fastp-qc/{sample}/.raw_fastqc.done", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/{sample}_fastp.html", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/clean_fastqc/{sample}_1_fastqc.html", sample=SAMPLES.index),
        expand("results/01-fastp-qc/{sample}/clean_fastqc/{sample}_2_fastqc.html", sample=SAMPLES.index),
        # STAR alignment + per-gene counts
        expand("results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam", sample=SAMPLES.index),
        # megadepth bigwig
        expand("results/03-megadepth-bigwig/{sample}/{sample}.all.bw", sample=SAMPLES.index),
        # merged count matrix
        "results/04-quant/counts.tsv",
        # DESeq2 differential expression
        "results/05-deseq2/normalized_counts.tsv",
        expand("results/05-deseq2/{contrast}.deseq2.tsv", contrast=CONTRASTS),

# ============================================================
# Step 1: FastQC on raw reads
# ============================================================
rule fastqc_raw:
    input:
        r1=lambda wc: SAMPLES.loc[wc.sample, "r1"],
        r2=lambda wc: SAMPLES.loc[wc.sample, "r2"],
    output:
        done=temp("results/01-fastp-qc/{sample}/.raw_fastqc.done"),
    log:
        "logs/01-fastp-qc/{sample}_fastqc_raw.log",
    params:
        threads=config["fastqc"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample}/raw_fastqc && "
        "pixi run -e default fastqc -o results/01-fastp-qc/{wildcards.sample}/raw_fastqc "
        "-t {params.threads} {input.r1} {input.r2} "
        "> {log} 2>&1 && "
        "touch {output.done}"

# ============================================================
# Step 2: fastp adapter trimming
# ============================================================
rule fastp:
    input:
        r1=lambda wc: SAMPLES.loc[wc.sample, "r1"],
        r2=lambda wc: SAMPLES.loc[wc.sample, "r2"],
    output:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
        html="results/01-fastp-qc/{sample}/{sample}_fastp.html",
        json="results/01-fastp-qc/{sample}/{sample}_fastp.json",
    log:
        "logs/01-fastp-qc/{sample}_fastp.log",
    params:
        length_required=config["fastp"]["length_required"],
        qual_phred=config["fastp"]["qualified_quality_phred"],
        unqual_limit=config["fastp"]["unqualified_percent_limit"],
        n_base=config["fastp"]["n_base_limit"],
        threads=config["fastp"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample} && "
        "pixi run -e default fastp "
        "-i {input.r1} -I {input.r2} "
        "-o {output.r1} -O {output.r2} "
        "-h {output.html} -j {output.json} "
        "--thread {params.threads} "
        "--detect_adapter_for_pe "
        "--length_required {params.length_required} "
        "--qualified_quality_phred {params.qual_phred} "
        "--unqualified_percent_limit {params.unqual_limit} "
        "--n_base_limit {params.n_base} "
        "> {log} 2>&1"

# ============================================================
# Step 3: FastQC on clean reads
# ============================================================
rule fastqc_clean:
    input:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
    output:
        r1_html="results/01-fastp-qc/{sample}/clean_fastqc/{sample}_1_fastqc.html",
        r2_html="results/01-fastp-qc/{sample}/clean_fastqc/{sample}_2_fastqc.html",
    log:
        "logs/01-fastp-qc/{sample}_fastqc_clean.log",
    params:
        threads=config["fastqc"]["threads"],
    shell:
        "mkdir -p results/01-fastp-qc/{wildcards.sample}/clean_fastqc && "
        "pixi run -e default fastqc -o results/01-fastp-qc/{wildcards.sample}/clean_fastqc "
        "-t {params.threads} {input.r1} {input.r2} "
        "> {log} 2>&1"

# ============================================================
# Step 4: STAR alignment + gene-level counts
# --quantMode GeneCounts writes {sample}.ReadsPerGene.out.tab, whose columns
# are: gene_id | unstranded | forward(yes) | reverse. The strandedness picked
# in config.yaml selects the right column when the matrix is merged (step 6).
# ============================================================
rule star_align:
    input:
        r1="results/01-fastp-qc/{sample}/{sample}_1.fastq.gz",
        r2="results/01-fastp-qc/{sample}/{sample}_2.fastq.gz",
        index=STAR_SAINDEX,
    output:
        bam="results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam",
        counts="results/02-read-alignment/{sample}/{sample}.ReadsPerGene.out.tab",
    log:
        "logs/02-read-alignment/{sample}.log",
    params:
        index_dir=STAR_INDEX,
        prefix="results/02-read-alignment/{sample}/{sample}.",
        threads=config["star"]["threads"],
        extra=config["star"]["extra"],
    shell:
        "mkdir -p results/02-read-alignment/{wildcards.sample} && "
        "pixi run -e star STAR "
        "--runThreadN {params.threads} "
        "--genomeDir {params.index_dir} "
        "--readFilesIn {input.r1} {input.r2} "
        "--readFilesCommand zcat "
        "--outSAMtype BAM SortedByCoordinate "
        "--quantMode GeneCounts "
        "--outFileNamePrefix {params.prefix} "
        "{params.extra} "
        "> {log} 2>&1"

# ============================================================
# Step 5: index BAM (needed by megadepth)
# ============================================================
rule index_bam:
    input:
        bam="results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam",
    output:
        bai="results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam.bai",
    log:
        "logs/02-read-alignment/{sample}_index.log",
    params:
        threads=config["samtools"]["threads"],
    shell:
        "pixi run -e star samtools index -@ {params.threads} {input.bam} > {log} 2>&1"

# ============================================================
# Step 6: megadepth coverage bigwig
# Writes {prefix}.all.bw (per-base coverage over all reads).
# ============================================================
rule megadepth_bigwig:
    input:
        bam="results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam",
        bai="results/02-read-alignment/{sample}/{sample}.Aligned.sortedByCoord.out.bam.bai",
    output:
        bw="results/03-megadepth-bigwig/{sample}/{sample}.all.bw",
    log:
        "logs/03-megadepth-bigwig/{sample}.log",
    params:
        prefix="results/03-megadepth-bigwig/{sample}/{sample}",
        threads=config["megadepth"]["threads"],
    shell:
        "mkdir -p results/03-megadepth-bigwig/{wildcards.sample} && "
        "pixi run -e megadepth megadepth {input.bam} "
        "--threads {params.threads} "
        "--bigwig --prefix {params.prefix} "
        "> {log} 2>&1"

# ============================================================
# Step 7: merge per-sample STAR counts into one matrix
# ============================================================
rule merge_counts:
    input:
        tabs=expand("results/02-read-alignment/{sample}/{sample}.ReadsPerGene.out.tab", sample=SAMPLES.index),
    output:
        counts="results/04-quant/counts.tsv",
    log:
        "logs/04-quant/merge_counts.log",
    params:
        strand=config["star"]["strandedness"],
        pairs=lambda wc: " ".join(
            f"{s}=results/02-read-alignment/{s}/{s}.ReadsPerGene.out.tab"
            for s in SAMPLES.index
        ),
    shell:
        "mkdir -p results/04-quant && "
        "pixi run -e default python scripts/merge_star_counts.py "
        "{params.strand} {output.counts} {params.pairs} "
        "> {log} 2>&1"

# ============================================================
# Step 8: DESeq2 differential expression
# Each non-reference group is compared against the first group (WT).
# ============================================================
rule deseq2:
    input:
        counts="results/04-quant/counts.tsv",
        samples="samples.tsv",
    output:
        norm="results/05-deseq2/normalized_counts.tsv",
        contrasts=expand("results/05-deseq2/{contrast}.deseq2.tsv", contrast=CONTRASTS),
    log:
        "logs/05-deseq2/deseq2.log",
    params:
        ref=REF_GROUP,
        padj=config["deseq2"]["padj_threshold"],
        lfc=config["deseq2"]["lfc_threshold"],
    shell:
        "mkdir -p results/05-deseq2 && "
        "pixi run -e deseq2 Rscript scripts/snakemake_deseq2.R "
        "{input.counts} {input.samples} results/05-deseq2 "
        "'{params.ref}' {params.padj} {params.lfc} "
        "> {log} 2>&1"
